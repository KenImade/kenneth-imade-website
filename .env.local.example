# Supabase — found in your project's API settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — bypasses RLS, server-only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Where contact form emails are delivered
OWNER_EMAIL=

# Random secret string used to secure the /api/revalidate endpoint
REVALIDATE_SECRET=
